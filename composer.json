{
    "name": "padosoft/laravel-iam-server",
    "description": "Server Laravel IAM: identity, organizations, Application Registry + manifest, PDP (RBAC+ABAC+ReBAC), OAuth (league/oauth2-server) + OIDC layer, audit tamper-evident, governance/IGA, Admin API + panel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "padosoft/laravel-iam-contracts": "^1.0",
        "spatie/laravel-package-tools": "^1.16",
        "lcobucci/jwt": "^5.0",
        "league/oauth2-server": "^9.0",
        "symfony/psr-http-message-bridge": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18"
    },
    "suggest": {
        "laravel/socialite": "Federated login (M5)",
        "laravel/fortify": "Auth backend nativo (M5)",
        "laravel/passkeys": "WebAuthn/passkey, assurance AAL2 (M5)",
        "aws/aws-sdk-php": "Driver AWS KMS/Secrets Manager (M3)",
        "laravel/ai": "Modulo AI — padosoft/laravel-iam-ai",
        "laravel/mcp": "MCP server — padosoft/laravel-iam-mcp",
        "directorytree/ldaprecord-laravel": "LDAP/AD — padosoft/laravel-iam-directory",
        "padosoft/laravel-iam-rebel": "Assurance avanzata (step-up/SCA/bot)"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\Iam\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "lint": "pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\Iam\\IamServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
