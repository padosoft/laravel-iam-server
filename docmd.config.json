        { "text": "Governance / IGA", "url": "/governance" }
      ]
    },
    { "text": "Admin API", "url": "/admin-api" },
    { "text": "Admin panel", "url": "/admin-panel" },
    { "text": "Reference", "url": "/reference" }
  ],
  "plugins": {
    "search": {},
    "seo": { "titleTemplate": "%s | Laravel IAM Server" },
